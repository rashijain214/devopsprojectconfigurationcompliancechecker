# Puppet-managed Nagios service definitions
# Monitors all aspects of the compliance checker

# ── Check HTTP endpoint is up ────────────────────────────────
define service {
  use                   generic-service
  host_name             compliance-checker-host
  service_description   HTTP Health Check
  check_command         check_http!-p 8080 -u /health
  max_check_attempts    3
  check_interval        5
  retry_interval        1
  notification_interval 30
  contact_groups        compliance-admins
}

# ── Check CPU usage ──────────────────────────────────────────
define service {
  use                   generic-service
  host_name             compliance-checker-host
  service_description   CPU Usage
  check_command         check_nrpe!check_cpu
