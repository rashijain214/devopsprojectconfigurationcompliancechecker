# ── Check disk space ─────────────────────────────────────────
define service {
  use                   generic-service
  host_name             compliance-checker-host
  service_description   Disk Space
  check_command         check_disk!-w 20% -c 10%
  max_check_attempts    3
  check_interval        10
  retry_interval        2
  notification_interval 60
  contact_groups        compliance-admins
}

